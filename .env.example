# Copy this file to .env and fill in your values.

# Telegram API credentials (get from https://my.telegram.org)
API_ID=
API_HASH=

# Your Max/VK phone number (international format)
MAX_PHONE=+7XXXXXXXXXX

# TDLib log level: 0=fatal, 1=errors, 2=warnings, 3=info, 4=debug (default: 1)
TDLIB_LOG_VERBOSITY=1
